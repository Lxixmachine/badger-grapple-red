{
  "name": "badger-grapple-red",
  "version": "22.15.0",
  "private": true,
  "type": "module",
  "description": "Source-first Phaser wrestling RPG built toward FireRed-style production quality",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build:camp-manifest": "python tools/build_camp_randall_manifest.py && python tools/build_camp_randall_tilemaps.py",
    "build:camp-production": "npm run build:world-tileset && python tools/build_camp_randall_production.py",
    "build:world-tileset": "python tools/build_season_one_world_tileset.py",
    "build:camp-metatiles": "npm run build:world-tileset && python tools/build_camp_randall_metatiles.py",
    "apply:map-editor": "python tools/apply_map_editor_project.py",
    "build:camp-tiles": "python tools/build_camp_randall_tilemaps.py",
    "build:world-compositions": "python tools/build_world_compositions.py",
    "build:maps": "npm run build:camp-manifest && npm run build:world-compositions",
    "validate": "node tools/validate.mjs",
    "balance": "node tools/balance_sim.mjs",
    "smoke": "playwright test",
    "check": "npm run build:maps && npm run build:camp-production && npm run build:camp-metatiles && npm run validate && npm run balance && npm run lint-maps && npm run build && npm run smoke",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint-maps": "node tools/lint_maps.mjs"
  },
  "dependencies": {
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@vitejs/plugin-basic-ssl": "latest",
    "phaser": "^3.90.0",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
