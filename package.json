{
  "name": "badger-grapple-red",
  "version": "21.61.0",
  "private": true,
  "type": "module",
  "description": "Source-first Phaser wrestling RPG built toward FireRed-style production quality",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build:camp-manifest": "python tools/build_camp_randall_manifest.py && python tools/build_camp_randall_tilemaps.py",
    "build:camp-tiles": "python tools/build_camp_randall_tilemaps.py",
    "validate": "node tools/validate.mjs",
    "balance": "node tools/balance_sim.mjs",
    "smoke": "playwright test",
    "check": "npm run validate && npm run balance && npm run lint-maps && npm run build && npm run smoke",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint-maps": "node tools/lint_maps.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "latest",
    "phaser": "^3.90.0",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
